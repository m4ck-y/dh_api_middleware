# Gateway Configuration
HOST=0.0.0.0
PORT=8000
BASE_PATH="/middleware"
# Deployment environment — sent as required field in every log to VitalTrace.
# Allows filtering logs by environment in the observability dashboard.
# Values: development | staging | production
ENVIRONMENT=development

# Microservices
# Pattern: SERVICE_<SERVICE_NAME>_URL
# RELEASED
SERVICE_AUTH_URL=http://127.0.0.1:8080
SERVICE_IAM_URL=http://127.0.0.1:8081
SERVICE_CORE_URL=http://127.0.0.1:8082
SERVICE_MFA_URL=http://127.0.0.1:8083
SERVICE_ONBOARDING_URL=http://127.0.0.1:8000
SERVICE_HEALTH_MONITORING_URL=http://127.0.0.1:8000/api/health-monitoring
# TESTING
SERVICE_LOGGER_TRACER_URL=http://127.0.0.1:8001
SERVICE_MESSAGE_SENDER_URL=http://127.0.0.1:8002
# PENDING
SERVICE_CATALOGS_URL=
SERVICE_ORGANIZATIONS_URL=
SERVICE_EXPEDIENT_URL=
